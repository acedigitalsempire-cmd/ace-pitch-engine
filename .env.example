# Ace Pitch Engine — Environment Variables
# Copy this file to .env for local development
# On Render: add these in the Environment tab of your service

# ── Required ──────────────────────────────────────────────────────────────────

# SerpApi key — https://serpapi.com
SERP_API_KEY=your_serpapi_key_here

# OpenAI API key — https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ── Email — Resend (Primary) ──────────────────────────────────────────────────
# When your domain is active, Resend is used automatically.
# Leave blank to fall back to Brevo.

RESEND_API_KEY=your_resend_key_here
RESEND_FROM_EMAIL=info@acedigitalsempire.com

# ── Email — Brevo SMTP (Fallback) ─────────────────────────────────────────────
# Used automatically when RESEND_API_KEY is not set or domain is expired.
# SMTP credentials from: brevo.com → SMTP & API → SMTP tab

BREVO_SMTP_USER=acedigitalsglobal@gmail.com
BREVO_SMTP_PASS=your_brevo_smtp_key_here

# ── Owner Copy ────────────────────────────────────────────────────────────────
# Your email — receives a copy of every pitch sent

OWNER_EMAIL=acedigitalsglobal@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────────

PORT=3000
