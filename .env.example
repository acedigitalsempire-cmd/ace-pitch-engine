# Ace Pitch Engine — Environment Variables
# Copy this file to .env for local development
# On Render: add these in the Environment tab of your service

# ── Required ──────────────────────────────────────────────────────────────────

# SerpApi key — https://serpapi.com
SERP_API_KEY=your_serpapi_key_here

# OpenAI API key — https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Resend API key — https://resend.com
RESEND_API_KEY=your_resend_key_here

# ── Email Config ──────────────────────────────────────────────────────────────

# From email address — use onboarding@resend.dev if domain is not verified yet
RESEND_FROM_EMAIL=onboarding@resend.dev

# Your personal email to receive a copy of every pitch sent
OWNER_EMAIL=jobhauntgithub@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────────

PORT=3000
